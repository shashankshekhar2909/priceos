rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products Catalog Match rules
    match /products/{productId} {
      // Public sandbox searches require read capability
      allow read: if true;
      
      // Strict admin lock for product indexing write
      allow write: if isAdmin();
    }

    // Secure Admin Settings and Secret Key vaults
    match /adminSettings/{settingId} {
      // Accessible exclusively by authorized system administrators
      allow read, write: if isAdmin();
    }
  }
}
